GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}
GOOGLE_IMPERSONATE_EMAIL=usuario@suaempresa.com
GOOGLE_TEAM_ROOT_FOLDER_ID=google-drive-folder-id-da-pasta-raiz-da-equipe

PORT=3000
NODE_ENV=development
